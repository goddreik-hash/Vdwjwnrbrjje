local function teleportTo(position)
    character = player.Character
    if not character then return end
    rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    rootPart.CFrame = CFrame.new(position + Vector3.new(0, -1, 0))
end

-- ══════════════════════════════════════
--     FARM LOOP
-- ══════════════════════════════════════
local function startFarm(statusLabel, eggCounter)
    if farmConnection then
        farmConnection:Disconnect()
        farmConnection = nil
    end

    local waiting = false
    lastPosition = nil
    lastMoveTime = tick()

    farmConnection = RunService.Heartbeat:Connect(function()
        if not farmActive then return end

        character = player.Character
        if not character then return end
        rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end

        local currentPos = rootPart.Position

        if lastPosition then
            local moved = (currentPos - lastPosition).Magnitude
            if moved > CONFIG.STUCK_THRESHOLD then
                lastMoveTime = tick()
                lastPosition = currentPos
            else
                if tick() - lastMoveTime >= CONFIG.STUCK_TIME then
                    if riverPosition then
                        statusLabel.Text = "🔄 Atascado, volviendo al río..."
                        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
                        teleportTo(riverPosition)
                        lastMoveTime = tick()
                        lastPosition = riverPosition
                        task.wait(0.5)
                    end
                end
            end
        else
            lastPosition = currentPos
        end

        local eggs = findEggs()

        if #eggs == 0 then
            if not waiting then
                waiting = true
                statusLabel.Text = "⏳ Sin huevos, esperando..."
                statusLabel.TextColor3 = Color3.fromRGB(255, 165, 0)
            end
            task.wait(CONFIG.SCAN_INTERVAL)
        else
            waiting = false
            statusLabel.Text = "✅ Farmeando... (" .. #eggs .. " huevos)"
            statusLabel.TextColor3 = Color3.fromRGB(80, 255, 80)

            for _, eggData in ipairs(eggs) do
                if not farmActive then break end
                teleportTo(eggData.position)
                lastMoveTime = tick()
                lastPosition = eggData.position
                eggCount = eggCount + 1
                eggCounter.Text = "🥚 Huevos: " .. eggCount
                task.wait(CONFIG.TELEPORT_DELAY)
            end

            task.wait(CONFIG.AUTO_RESPAWN_CHECK)
        end
    end)
end

