-- ══════════════════════════════════════
--        BUSCAR HUEVOS
-- ══════════════════════════════════════
local function findEggs()
    local eggs = {}

    local function searchIn(parent)
        for _, obj in ipairs(parent:GetChildren()) do
            if obj:IsA("BasePart") or obj:IsA("Model") or obj:IsA("Part") then
                local nameLow = obj.Name:lower()

                local isIgnored = false
                for _, ignoreName in ipairs(CONFIG.IGNORE_NAMES) do
                    if nameLow == ignoreName:lower() or nameLow:find(ignoreName:lower(), 1, true) then
                        isIgnored = true
                        break
                    end
                end

                if not isIgnored then
                    if nameLow:find("easter") or nameLow:find("decor") or
                       nameLow:find("ornament") or nameLow:find("prop") or
                       nameLow:find("static") or nameLow:find("display") or
                       nameLow:find("pedestal") or nameLow:find("base") or
                       nameLow:find("chocolate dipped") or nameLow:find("striped candy") then
                        isIgnored = true
                    end
                end

                if not isIgnored then
                    for _, eggName in ipairs(CONFIG.EGG_NAMES) do
                        if nameLow:find(eggName:lower(), 1, true) then
                            local pos
                            if obj:IsA("Model") and obj.PrimaryPart then
                                pos = obj.PrimaryPart.Position
                            elseif obj:IsA("BasePart") then
                                pos = obj.Position
                            end
                            if pos then
                                local dist = (rootPart.Position - pos).Magnitude
                                if dist <= CONFIG.MAX_DISTANCE then
                                    table.insert(eggs, {position = pos, distance = dist})
                                end
                            end
                            break
                        end
                    end
                end
            end

            if obj:IsA("Folder") or obj:IsA("Model") then
                searchIn(obj)
            end
        end
    end

    searchIn(game.Workspace)
    table.sort(eggs, function(a, b) return a.distance < b.distance end)
    return eggs
end

